# Extension 環境變數（複製為 .env.local 填入真實值）
VITE_API_BASE_URL=https://newslens-api.newslens.workers.dev

# 搜尋分潤 Partner Code（向 Yahoo/Bing 申請）
VITE_YAHOO_HSPART=your_yahoo_partner_id
VITE_YAHOO_HSIMP=yhs-001
VITE_BING_PC=YOUR_BING_PC
VITE_BING_FORM=YOUR_FORM_CODE

# Worker 環境變數（透過 wrangler secret 設定）
# wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...
