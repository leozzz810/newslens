{
  "manifest_version": 3,
  "name": "NewsLens — AI 新聞儀表板",
  "version": "1.0.0",
  "description": "每次開新分頁，就是你的 AI 策展新聞牆——全網新聞按興趣分類、自動摘要、每日更新。",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://newslens-api.newslens.workers.dev/*"
  ],
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "options_page": "src/options/index.html",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "NewsLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
